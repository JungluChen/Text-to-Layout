# Text-to-Layout plugin server configuration.
# Copy to .env and adjust. All values are optional (defaults shown).

# Host/port for `python -m textlayout.backend` and `textlayout serve`.
TEXTLAYOUT_HOST=127.0.0.1
TEXTLAYOUT_PORT=8000

# Directory where generated GDS/SVG/JSON artifacts are written.
TEXTLAYOUT_WORKSPACE=workspace/textlayout

# --- Future (agent layer; not required to run the deterministic core/API) ---
# An LLM key is only needed once the natural-language Planner/Layout agents are
# wired in. The DSL → geometry → verify → export pipeline needs no API key.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
