            "z0_ohm": "float",
            "frequency_ghz": "float",
            "quality_factor": "float",
            "gain_db": "float",
            "bandwidth_ghz": "float"
        },
        "fabrication": {
            "process": "string",
            "metal": "string",
            "substrate": "string",
            "junction_type": "string"
        },
        "ports": [{"name": "string", "type": "string"}],
        "ground_strategy": "string (coplanar|microstrip|none)",
        "flux_strategy": "string (none|inductive|capacitive)",
        "readout_strategy": "string (none|side_coupled|end_coupled|3d_cavity)",
        "cpw_transition": "string (uniform|tapered|stepped)",
        "idc_style": "string (none|standard|tapped|folded)",
        "squid_style": "string (none|planar|window|uncertainty)"
    }
