            "jj_area_um2": "float",
            "cpw_width_um": "float",
            "cpw_gap_um": "float",
            "chip_area_um2": "float",
            "idc_finger_count": "int",
            "idc_finger_length_um": "float"
        },
        "topology_features": {
            "node_types": ["list of node types"],
            "edge_types": ["list of edge types"]
