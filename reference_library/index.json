        "topology": "string (pocket_transmon|xmon|concentric_transmon|lumped_jpa|quarter_wave_jpa|twpa|fluxonium|cpw_resonator|idc_resonator|calibration_chip|jj_array)",
        "institution": "string",
        "reference": "string (citation)",
